# Database Configuration
# IMPORTANT: Change these credentials before deploying!
POSTGRES_DB=sharks
POSTGRES_USER=sharks
POSTGRES_PASSWORD=changeme_use_strong_password
DATABASE_URL=postgresql+psycopg://sharks:changeme_use_strong_password@db:5432/sharks

# Redis Configuration
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# API Configuration
ALLOWED_ORIGINS=http://localhost:3000
API_TITLE=Sharks Aggregator API
API_VERSION=0.1.0

# Ingestion Settings
INGEST_INTERVAL_MINUTES=10
MAX_FETCH_RETRIES=3
REQUEST_TIMEOUT_SECONDS=30
MAX_ARTICLE_AGE_DAYS=7

# Clustering Settings
CLUSTER_TIME_WINDOW_HOURS=72
CLUSTER_SIMILARITY_THRESHOLD=0.62
ENTITY_OVERLAP_THRESHOLD=0.50
TOKEN_SIMILARITY_THRESHOLD=0.40

# Rate Limiting
SUBMISSION_RATE_LIMIT_PER_IP=10
# Per-client limit for public counter endpoints (/metrics/pageview,
# /cluster/{id}/click). Generous on purpose — just stops trivial spam.
METRICS_RATE_LIMIT_PER_MIN=60

# OpenRouter LLM Settings (Gemma 4 via openrouter.ai)
OPENROUTER_API_KEY=        # Get from openrouter.ai/keys
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_TIMEOUT_SECONDS=45
LLM_RELEVANCE_ENABLED=true
LLM_EVALUATION_MODE=false
LLM_TAGGING_ENABLED=true
LLM_CLUSTERING_ENABLED=true

# Admin Settings
# REQUIRED. Admin API key the Next.js proxy injects as X-Admin-API-Key. If empty,
# ALL admin requests are denied (fail closed) — there is no IP-allowlist fallback.
# Generate one, e.g.: openssl rand -hex 32
ADMIN_API_KEY=
# HTTP Basic credentials gating the /admin page and /api/admin proxy routes in
# the Next.js app (server-side only; never exposed to the browser).
ADMIN_PANEL_USER=admin
ADMIN_PANEL_PASSWORD=
# Trusted proxies whose X-Forwarded-For is honored (the Docker bridge / Next.js
# container). Comma-separated IPs/CIDRs.
TRUSTED_PROXY_IPS=127.0.0.1,::1,172.16.0.0/12

# BlueSky Posting Settings
BLUESKY_ENABLED=false
BLUESKY_HANDLE=sjsharks-news.bsky.social
BLUESKY_APP_PASSWORD=  # Get from bsky.app > Settings > App Passwords
BLUESKY_MIN_SOURCES=1
BLUESKY_POST_INTERVAL_MINUTES=15

# Frontend Configuration
# INTERNAL_API_URL is used by Next.js API routes to proxy requests to the backend.
# The browser never talks directly to the backend - all requests go through Next.js.
# In Docker, use the service name (e.g., http://api:8000)
# Locally, use http://localhost:8001
INTERNAL_API_URL=http://localhost:8001
